{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run export && cp dist/+not-found.html dist/404.html",
  "outputDirectory": "dist",
  "framework": null,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/catalog" },
    { "source": "/product/(.*)", "destination": "/product/[id]" }
  ]
}
